{
  "name": "newsapi.org",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npx tsc",
    "build:lambda:collector:newsapi-ai": "esbuild src/articles/lambda/newsapi-ai_collector_lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/articles/lambda/newsapi-ai-collector_lambda.js",
    "build:lambda:loader:newsapi-ai": "esbuild src/articles/lambda/newsapi-ai_loader_lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/articles/lambda/newsapi-ai-loader_lambda.js",
    "zip:lambda:collector:newsapi-ai": "node scripts/zip-lambda.js dist/articles/lambda/newsapi-ai-collector_lambda.js dist/articles/lambda/newsapi-ai-collector_lambda.zip",
    "zip:lambda:loader:newsapi-ai": "node scripts/zip-lambda.js dist/articles/lambda/newsapi-ai-loader_lambda.js dist/articles/lambda/newsapi-ai-loader_lambda.zip",
    "package:lambda:collector:newsapi-ai": "npm run build:lambda:collector:newsapi-ai && npm run zip:lambda:collector:newsapi-ai",
    "package:lambda:loader:newsapi-ai": "npm run build:lambda:loader:newsapi-ai && npm run zip:lambda:loader:newsapi-ai",
    "build:lambda:collector:events": "esbuild src/events/lambda/event_collector_lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/events/lambda/event-collector_lambda.js",
    "build:lambda:loader:events": "esbuild src/events/lambda/event_loader_lambda.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/events/lambda/event-loader_lambda.js",
    "zip:lambda:collector:events": "node scripts/zip-lambda.js dist/events/lambda/event-collector_lambda.js dist/events/lambda/event-collector_lambda.zip",
    "zip:lambda:loader:events": "node scripts/zip-lambda.js dist/events/lambda/event-loader_lambda.js dist/events/lambda/event-loader_lambda.zip",
    "package:lambda:collector:events": "npm run build:lambda:collector:events && npm run zip:lambda:collector:events",
    "package:lambda:loader:events": "npm run build:lambda:loader:events && npm run zip:lambda:loader:events",
    "package:lambdas": "npm run package:lambda:collector:newsapi-ai && npm run package:lambda:loader:newsapi-ai && npm run package:lambda:collector:events && npm run package:lambda:loader:events"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "dotenv": "^17.3.1",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.4",
    "@types/pg": "^8.18.0",
    "@types/pg-copy-streams": "^1.2.5",
    "archiver": "^7.0.1",
    "esbuild": "^0.27.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
