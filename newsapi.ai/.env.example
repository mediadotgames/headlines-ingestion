############################################################
# MDG Headlines Ingestion — Environment Configuration
#
# This file documents all environment variables used by the
# EventRegistry collectors and loaders.
#
# There are two execution environments:
#
# 1. Local development collectors/loaders
# 2. AWS Lambda production collectors/loaders
#
# Some variables are shared, while others are environment
# specific.
############################################################



############################################################
# EventRegistry / NewsAPI.ai
############################################################

# API key for EventRegistry
# https://newsapi.ai
EVENTREGISTRY_API_KEY=

# Comma-separated list of news source domains to ingest.
#
# Used ONLY in normal "date window" collection mode.
#
# Example:
# EVENTREGISTRY_SOURCE_URIS=apnews.com,reuters.com,bbc.com
#
# In article URI repair mode this variable is ignored.
EVENTREGISTRY_SOURCE_URIS=aljazeera.com,apnews.com,bbc.com,foxnews.com,ms.now,nytimes.com,politico.com,reuters.com,scmp.com,washingtonpost.com,wsj.com



############################################################
# Collector Mode
############################################################

# Controls how the collector fetches articles.
#
# Allowed values:
#
# date_window
#   Normal ingestion mode using EventRegistry search API
#   with time windows and pagination.
#
# article_uri_list
#   Backfill / repair mode that fetches articles directly
#   by URI using the EventRegistry article details endpoint.
#
# Default: date_window
COLLECTOR_MODE=date_window



############################################################
# Article URI Repair Mode (optional)
#
# Only used when:
#
# COLLECTOR_MODE=article_uri_list
############################################################

# Provide a JSON array of article URIs.
#
# Example:
# ARTICLE_URI_LIST_JSON=["123456","987654","456789"]
#
# Useful for small manual repair runs.
ARTICLE_URI_LIST_JSON=

# Local file path containing a JSON array of article URIs.
#
# Example:
# ARTICLE_URI_LIST_PATH=./tmp/article_uris.json
#
# File format:
# [
#   "123456",
#   "987654",
#   "456789"
# ]
#
# Used only for LOCAL collectors.
ARTICLE_URI_LIST_PATH=

# S3 URI pointing to a JSON file containing article URIs.
#
# Example:
# ARTICLE_URI_LIST_S3_URI=s3://my-bucket/repairs/article_uris.json
#
# Used only by Lambda collectors.
ARTICLE_URI_LIST_S3_URI=

# Number of article URIs to request per API call.
#
# EventRegistry allows up to ~100 URIs per request.
#
# Recommended values:
# 50–100
ARTICLE_URI_BATCH_SIZE=100



############################################################
# Postgres Database
############################################################

# Database connection string used by loaders
# and collectors that reserve pipeline runs.
#
# Example:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=



############################################################
# Artifact Output (Lambda only)
############################################################

# S3 bucket where artifact bundles will be uploaded.
#
# Lambda collectors write artifacts to /tmp and then upload
# them to this bucket.
ARTIFACT_BUCKET=

# S3 prefix used for artifact storage.
#
# Example:
# ARTIFACT_PREFIX=newsapi/articles
#
# Resulting S3 layout might look like:
#
# s3://bucket/newsapi/articles/2026-03-12/run_id/
ARTIFACT_PREFIX=



############################################################
# Window Controls (date_window mode only)
############################################################

# Number of days to look back when collecting articles.
#
# Example:
# LOOKBACK_DAYS=2
#
# If today is March 10 and LOOKBACK_DAYS=2,
# collection starts on March 8.
LOOKBACK_DAYS=2

# Offset from current day for the window end.
#
# Example:
# WINDOW_END_DAYS_AGO=0
#
# This allows delaying ingestion slightly to allow
# articles to accumulate.
WINDOW_END_DAYS_AGO=0

# Override the date anchor for article collection.
#
# When set, LOOKBACK_DAYS and WINDOW_END_DAYS_AGO are ignored.
# The collector fetches articles for exactly this single
# calendar day (midnight to midnight in the canonical timezone).
#
# Format: ISO 8601 date (YYYY-MM-DD)
#
# Example:
# BACKFILL_LOCAL_DATE=2026-03-01
#
# Useful for targeted single-day backfills without adjusting
# the lookback/offset math.
BACKFILL_LOCAL_DATE=



############################################################
# Run Tracking
############################################################

# Type of pipeline run.
#
# Allowed values:
#
# scheduled
#   Normal recurring ingestion.
#
# backfill
#   Historical backfill or repair run.
#
# seed
#   Initial dataset seeding.
RUN_TYPE=scheduled



############################################################
# LOCAL EXECUTION EXAMPLE
############################################################

# Example local scheduled ingestion run
#
# COLLECTOR_MODE=date_window
# RUN_TYPE=scheduled
# LOOKBACK_DAYS=2
# WINDOW_END_DAYS_AGO=0



############################################################
# LOCAL ARTICLE REPAIR EXAMPLE
############################################################

# Example backfill run using article URIs
#
# COLLECTOR_MODE=article_uri_list
# RUN_TYPE=backfill
# ARTICLE_URI_LIST_PATH=./tmp/article_uris.json
# ARTICLE_URI_BATCH_SIZE=100



############################################################
# LAMBDA ARTICLE REPAIR EXAMPLE
############################################################

# Example Lambda backfill run using S3 URI list
#
# COLLECTOR_MODE=article_uri_list
# RUN_TYPE=backfill
# ARTICLE_URI_LIST_S3_URI=s3://bucket/repairs/article_uris.json
# ARTICLE_URI_BATCH_SIZE=100

############################################################
# Event Ingestion Pipeline
#
# The event pipeline runs AFTER articles are loaded.
#
# The event collector discovers event URIs referenced by
# articles and fetches event objects from EventRegistry.
#
# The event loader then ingests those events into the
# public.events table.
############################################################


############################################################
# Event Discovery Scope
############################################################

# Controls how the event collector selects articles to inspect
# when discovering event URIs.
#
# Allowed values:
#
# parent_run
#   Default mode. Inspect only the articles loaded by the
#   triggering article pipeline run.
#
# time_window
#   Inspect articles within a specified time window.
#
# full_corpus
#   Scan the entire newsapi_articles table.
#
# custom_filter
#   Reserved for future custom discovery logic.
#
EVENT_DISCOVERY_SCOPE=parent_run


############################################################
# Time Window Discovery Mode (optional)
#
# Only used when:
#
# EVENT_DISCOVERY_SCOPE=time_window
############################################################

# Column used to determine article time range
#
# Allowed values:
#
# ingested_at
# date_time_published
# created_at
#
EVENT_DISCOVERY_TIME_COLUMN=ingested_at

# Start timestamp (ISO8601)
EVENT_DISCOVERY_START=

# End timestamp (ISO8601)
EVENT_DISCOVERY_END=

# Comma-separated list of source domains to restrict event
# discovery to. When set, only articles from these sources
# are scanned for event URIs.
#
# Currently recorded in manifest metadata for auditing.
# If empty, all sources in the article corpus are included.
#
# Example:
# EVENT_DISCOVERY_SOURCE_URIS=apnews.com,reuters.com,bbc.com
EVENT_DISCOVERY_SOURCE_URIS=



############################################################
# Event Freshness Controls
############################################################

# Only fetch events that are not already present in the
# public.events table.
#
# true  → fetch missing events only
# false → allow refreshing stale events
#
EVENT_DISCOVERY_ONLY_MISSING=false

# Whether to refresh events that already exist but are stale.
#
EVENT_DISCOVERY_INCLUDE_STALE=true

# Events older than this threshold will be refreshed.
#
# Units: hours
#
EVENT_STALE_AFTER_HOURS=24



############################################################
# Event Discovery Limits
############################################################

# Maximum number of articles scanned when discovering events.
#
EVENT_DISCOVERY_MAX_ARTICLES=50000

# Maximum number of distinct event URIs selected for fetching.
#
EVENT_DISCOVERY_MAX_EVENT_URIS=10000


############################################################
# Event API Fetch Controls
############################################################

# Number of event URIs to request per EventRegistry API call.
#
# EventRegistry accepts an array of URIs for the
# /api/v1/event/getEvent endpoint, so the collector batches
# requests instead of making one call per URI.
#
# Recommended values: 50–100
#
# Lower this if you encounter rate limit errors or timeouts.
# Raise it toward 100 to minimize API round trips on large runs.
#
# Default: 50
EVENT_FETCH_BATCH_SIZE=50

# Maximum number of retry attempts per API call.
#
# Default: 5
FETCH_MAX_ATTEMPTS=5


############################################################
# Parent Article Run Overrides (optional)
#
# These are ONLY used when:
#
# EVENT_DISCOVERY_SCOPE=parent_run
#
# Normal behavior:
#   The local event collector should read the latest local
#   article load_report.json.
#
#   The Lambda event collector should read the triggering
#   article load_report.json from S3.
#
# These variables are optional OVERRIDES for manual replay,
# debugging, or targeted testing.
############################################################

# Parent article pipeline run ID
#
# Example:
# PARENT_RUN_ID=2026-03-13T10:00:00.000Z
#
PARENT_RUN_ID=

# Parent article pipeline run type
#
# Allowed values:
# scheduled
# backfill
# seed
#
PARENT_RUN_TYPE=

# Parent article pipeline nth_run
#
# Example:
# PARENT_NTH_RUN=1
#
PARENT_NTH_RUN=

# Parent article ingestion source
#
# Normally:
# newsapi-ai
#
PARENT_INGESTION_SOURCE=

############################################################
# EVENT TIME WINDOW EXAMPLE
#
# Use this to collect events for all articles ingested in
# the last 72 hours, regardless of which pipeline run
# loaded them.
#
# EVENT_DISCOVERY_SCOPE=time_window uses explicit ISO8601
# timestamps — the collector does not compute relative
# windows itself. Generate EVENT_DISCOVERY_START and
# EVENT_DISCOVERY_END before invoking the collector.
#
# Bash example (72-hour lookback ending now):
#
#   export EVENT_DISCOVERY_START=$(date -u -d '72 hours ago' '+%Y-%m-%dT%H:%M:%SZ')
#   export EVENT_DISCOVERY_END=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
#
# PowerShell example (72-hour lookback ending now):
#
#   $env:EVENT_DISCOVERY_START = (Get-Date).ToUniversalTime().AddHours(-72).ToString("yyyy-MM-ddTHH:mm:ssZ")
#   $env:EVENT_DISCOVERY_END   = (Get-Date).ToUniversalTime().ToString("yyyy-MM-ddTHH:mm:ssZ")
#
# Note: in time_window mode, PARENT_RUN_ID / PARENT_RUN_TYPE
# / PARENT_NTH_RUN are ignored. The collector writes no
# event_collect metrics to pipeline_run_metrics because
# there is no parent pipeline_runs row to attach them to.
############################################################

# EVENT_DISCOVERY_SCOPE=time_window
# EVENT_DISCOVERY_TIME_COLUMN=ingested_at
# EVENT_DISCOVERY_START=2026-03-10T00:00:00Z
# EVENT_DISCOVERY_END=2026-03-13T00:00:00Z
# RUN_TYPE=backfill
# EVENT_DISCOVERY_ONLY_MISSING=false
# EVENT_DISCOVERY_INCLUDE_STALE=true
# EVENT_STALE_AFTER_HOURS=24
