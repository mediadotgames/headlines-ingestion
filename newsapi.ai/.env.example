############################################################
# MDG Headlines Ingestion — Environment Configuration
#
# This file documents all environment variables used by the
# EventRegistry collectors and loaders.
#
# There are two execution environments:
#
# 1. Local development collectors/loaders
# 2. AWS Lambda production collectors/loaders
#
# Some variables are shared, while others are environment
# specific.
############################################################



############################################################
# EventRegistry / NewsAPI.ai
############################################################

# API key for EventRegistry
# https://newsapi.ai
EVENTREGISTRY_API_KEY=

# Comma-separated list of news source domains to ingest.
#
# Used ONLY in normal "date window" collection mode.
#
# Example:
# EVENTREGISTRY_SOURCE_URIS=apnews.com,reuters.com,bbc.com
#
# In article URI repair mode this variable is ignored.
EVENTREGISTRY_SOURCE_URIS=aljazeera.com,apnews.com,bbc.com,foxnews.com,ms.now,nytimes.com,politico.com,reuters.com,scmp.com,washingtonpost.com,wsj.com



############################################################
# Collector Mode
############################################################

# Controls how the collector fetches articles.
#
# Allowed values:
#
# date_window
#   Normal ingestion mode using EventRegistry search API
#   with time windows and pagination.
#
# article_uri_list
#   Backfill / repair mode that fetches articles directly
#   by URI using the EventRegistry article details endpoint.
#
# Default: date_window
COLLECTOR_MODE=date_window



############################################################
# Article URI Repair Mode (optional)
#
# Only used when:
#
# COLLECTOR_MODE=article_uri_list
############################################################

# Provide a JSON array of article URIs.
#
# Example:
# ARTICLE_URI_LIST_JSON=["123456","987654","456789"]
#
# Useful for small manual repair runs.
ARTICLE_URI_LIST_JSON=

# Local file path containing a JSON array of article URIs.
#
# Example:
# ARTICLE_URI_LIST_PATH=./tmp/article_uris.json
#
# File format:
# [
#   "123456",
#   "987654",
#   "456789"
# ]
#
# Used only for LOCAL collectors.
ARTICLE_URI_LIST_PATH=

# S3 URI pointing to a JSON file containing article URIs.
#
# Example:
# ARTICLE_URI_LIST_S3_URI=s3://my-bucket/repairs/article_uris.json
#
# Used only by Lambda collectors.
ARTICLE_URI_LIST_S3_URI=

# Number of article URIs to request per API call.
#
# EventRegistry allows up to ~100 URIs per request.
#
# Recommended values:
# 50–100
ARTICLE_URI_BATCH_SIZE=100



############################################################
# Postgres Database
############################################################

# Database connection string used by loaders
# and collectors that reserve pipeline runs.
#
# Example:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=



############################################################
# Artifact Output (Lambda only)
############################################################

# S3 bucket where artifact bundles will be uploaded.
#
# Lambda collectors write artifacts to /tmp and then upload
# them to this bucket.
ARTIFACT_BUCKET=

# S3 prefix used for artifact storage.
#
# Example:
# ARTIFACT_PREFIX=newsapi/articles
#
# Resulting S3 layout might look like:
#
# s3://bucket/newsapi/articles/2026-03-12/run_id/
ARTIFACT_PREFIX=



############################################################
# Window Controls (date_window mode only)
############################################################

# Number of days to look back when collecting articles.
#
# Example:
# LOOKBACK_DAYS=2
#
# If today is March 10 and LOOKBACK_DAYS=2,
# collection starts on March 8.
LOOKBACK_DAYS=2

# Offset from current day for the window end.
#
# Example:
# WINDOW_END_DAYS_AGO=0
#
# This allows delaying ingestion slightly to allow
# articles to accumulate.
WINDOW_END_DAYS_AGO=0



############################################################
# Run Tracking
############################################################

# Type of pipeline run.
#
# Allowed values:
#
# scheduled
#   Normal recurring ingestion.
#
# backfill
#   Historical backfill or repair run.
#
# seed
#   Initial dataset seeding.
RUN_TYPE=scheduled



############################################################
# LOCAL EXECUTION EXAMPLE
############################################################

# Example local scheduled ingestion run
#
# COLLECTOR_MODE=date_window
# RUN_TYPE=scheduled
# LOOKBACK_DAYS=2
# WINDOW_END_DAYS_AGO=0



############################################################
# LOCAL ARTICLE REPAIR EXAMPLE
############################################################

# Example backfill run using article URIs
#
# COLLECTOR_MODE=article_uri_list
# RUN_TYPE=backfill
# ARTICLE_URI_LIST_PATH=./tmp/article_uris.json
# ARTICLE_URI_BATCH_SIZE=100



############################################################
# LAMBDA ARTICLE REPAIR EXAMPLE
############################################################

# Example Lambda backfill run using S3 URI list
#
# COLLECTOR_MODE=article_uri_list
# RUN_TYPE=backfill
# ARTICLE_URI_LIST_S3_URI=s3://bucket/repairs/article_uris.json
# ARTICLE_URI_BATCH_SIZE=100